{
    "name":  "portfolio-mri-frontend",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Clean Next.js/React frontend prototype for Portfolio MRI Investment Decision Room.",
    "scripts":  {
                    "dev":  "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/start_local_site.ps1",
                    "dev:local":  "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/start_local_site.ps1",
                    "dev:next":  "next dev",
                    "build":  "next build",
                    "start":  "next start",
                    "lint":  "next lint",
                    "typecheck":  "tsc --noEmit",
                    "test:api":  "node --test tests/api-route-tests.cjs",
                    "test:smoke":  "node --test tests/frontend-smoke-tests.cjs",
                    "qa:vertical":  "node ../scripts/qa_browser_vertical.cjs"
                },
    "dependencies":  {
                         "@supabase/ssr":  "^0.12.0",
                         "@supabase/supabase-js":  "^2.108.1",
                         "next":  "^14.2.4",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1"
                     },
    "devDependencies":  {
                            "@types/node":  "^20.14.10",
                            "@types/react":  "^18.3.3",
                            "@types/react-dom":  "^18.3.0",
                            "autoprefixer":  "^10.4.19",
                            "playwright":  "^1.60.0",
                            "postcss":  "^8.4.39",
                            "tailwindcss":  "^3.4.4",
                            "typescript":  "^5.5.3"
                        }
}
