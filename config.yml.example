# =============================================================================
# Portfolio MRI / Portfolio X-Ray — Example Configuration
# Copy to config.yml and adjust.
#
# Core MVP (portfolio-first diagnosis): only Section 1 is required.
#   python run_portfolio_review.py
#   python run_portfolio_review.py --candidates equal_weight
#
# Legacy policy optimization and full mandate controls: Sections 4–7.
# =============================================================================

# =============================================================================
# SECTION 1 — CORE MVP INPUT (required for diagnosis-first product flow)
# =============================================================================
# User-facing fields per docs/specs/input_assumptions_spec.md § Core MVP Input Surface.
# System injects analysis_subject.type=current_portfolio and
# analysis_mode=analyze_current_weights when you supply current_weights or weights.

investor_currency: USD  # USD | EUR | JPY | CHF

tickers: [SPY, QQQ, GLD, SLV, BND, SCHD, SCHP, TLT]

# Allocation: use current_weights (preferred) or weights. Percent strings allowed.
current_weights:
  SPY: 0.10
  QQQ: 0.13
  GLD: 0.09
  SLV: 0.09
  BND: 0.16
  SCHD: 0.17
  SCHP: 0.13
  TLT: 0.13

# Optional explicit bank cash (zero return; not replaced by cash_proxy_ticker):
# tickers: [VOO, BND, Cash USD]
# current_weights: {VOO: 0.45, BND: 0.45, Cash USD: 0.10}

# USD defaults (risk-free, cash proxy, benchmark) are injected when omitted.
# Non-USD may require explicit risk_free_source and cash_proxy_ticker — see Section 2.

# =============================================================================
# SECTION 2 — SYSTEM / MARKET DEFAULTS (optional overrides)
# =============================================================================
# Normally leave commented for USD Core MVP. Uncomment to override currency defaults.

# risk_free_source: FRED:DTB3
# cash_proxy_ticker: BIL
# base_benchmark_ticker: SPY
# beta_local_mapping: {}

# =============================================================================
# SECTION 3 — EXPLICIT analysis_subject (optional; advanced clarity)
# =============================================================================
# If omitted, Core MVP infers current_portfolio from current_weights/weights.
# Use this block when you need model_portfolio, universe_baseline, or custom ids.

# analysis_subject:
#   type: current_portfolio
#   id: analysis_subject
#   display_name: Current Portfolio
#   weights: {VOO: 0.45, QQQ: 0.20, GLD: 0.10, BND: 0.20, VT: 0.05}

# Legacy compatibility (optimizer path only when no user weights):
# analysis_mode: optimize_from_universe

# =============================================================================
# SECTION 4 — CLIENT FIT / LIQUIDITY (later product layers; not Core MVP)
# =============================================================================

# initial_investable_amount: 1000
# liquidity_need_months: 0
# monthly_expenses: 0
# portfolio_value: null
# cash_policy: allowed_for_scaling  # allowed_for_scaling | required_floor | prohibited

# =============================================================================
# SECTION 5 — CLIENT PROFILE AND TARGETS (legacy optimizer / mandate)
# =============================================================================

# client_profile: null  # ultra_conservative | conservative | balanced | growth | aggressive

# allow_leverage: false
# allow_short_selling: false
# min_acceptable_return: null
# target_nominal_return_annual: 0.1
# target_vol_annual: 0.15
# target_max_drawdown_pct: -0.3
# horizon_years: 10.0

# =============================================================================
# SECTION 6 — OPTIMIZATION CONSTRAINTS (legacy policy path)
# =============================================================================

# max_single_security_weight_pct: null
# min_single_security_weight_pct: null
# N_rc: 3
# donor_shift_mode: proportional
# minimum_variance_turnover_lambda: 0
# minimum_variance_l1_experimental: false
# minimum_cvar_confidence_level: 0.95
# robust_mv_covariance_method: ledoit_wolf
# robust_mv_mu_shrinkage_method: james_stein

# risk_budgeting:
#   preset: balanced
#   targets: {}
#   missing_taxonomy: exclude
#   drop_empty_buckets: false
#   asset_targets: {}

# =============================================================================
# SECTION 7 — ANALYSIS AND OUTPUT SETTINGS (technical; optional)
# =============================================================================

# windows_months: [36, 60, 120]
# returns_frequency: monthly  # monthly | weekly | daily (non-monthly is disclosure-only)
# market_data_provider: yfinance  # yfinance | ibkr | ibkr_yfinance_fallback
# coverage_threshold: 0.9
# output_dir: results_csv
# output_dir_final: "Main portfolio"

# optimization_windows_months: [120, 60]
# primary_window_months: 120
# secondary_window_months: 60
# robustness_policy:
#   enabled: true
#   max_weight_change_allowed: 0.10
#   max_asset_rc_dev_allowed: 0.05
#   min_effective_months: 36

# backtest_mode: dynamic_nan_safe
