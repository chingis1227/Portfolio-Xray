# =============================================================================
# Portfolio Metrics Standard — Example Configuration
# Copy to config.yml and adjust. All portfolio assumptions are controlled here.
# =============================================================================

# =============================================================================
# SECTION 1: CORE SETTINGS
# =============================================================================
# investor_currency: на выбор — USD (доллар), EUR (евро), JPY (йена), CHF (франк).

investor_currency: USD
initial_investable_amount: 1000
liquidity_need: 0

# ---------- Liquidity (life floor): liquidity_amount = liquidity_need_months × monthly_expenses ----------
# Months of expenses to cover (0 = life floor off). Any non-negative number, including decimal (e.g. 2, 2.5).
liquidity_need_months: 0
# Monthly expenses in investor_currency. Used only if liquidity_need_months > 0.
monthly_expenses: 0
# Current portfolio market value in investor_currency. If null or not set, initial_investable_amount is used.
portfolio_value: null

# ---------- Cash policy (choose one) ----------
# allowed_for_scaling (default) | required_floor | prohibited
# - allowed_for_scaling: floor may be 0; cash can be used for vol scaling toward target_vol_annual.
# - required_floor: cash at least liquidity floor; vol-scaling cash allowed.
# - prohibited: no cash; TargetVol only via RiskPortfolio restructuring.
cash_policy: allowed_for_scaling

# =============================================================================
# SECTION 2: RISK-FREE AND BENCHMARK
# =============================================================================
# Optional: if omitted, defaults are injected (base_benchmark_ticker from investor_currency;
# risk_free_source and cash_proxy_ticker from currency in code).
# cash_proxy_ticker: from investor_currency (e.g. BIL for USD, PEU for EUR). Set explicitly or by default.
# base_benchmark_ticker: if missing, set from currency (USD->SPY, EUR->VGK, JPY->EWJ, CHF->EWL).

risk_free_source: FRED:DTB3
cash_proxy_ticker: BIL
base_benchmark_ticker: SPY
beta_local_mapping: {}

# =============================================================================
# SECTION 3: PORTFOLIO TICKERS AND WEIGHTS
# =============================================================================
# tickers: list of instruments (cash proxy, e.g. BIL, is excluded from the risk optimization universe).
# weights: do not set by hand. Produced by optimization; export and save here after optimization.

tickers: [VOO, QQQ, GLD, BND, VT]

weights: {}

# =============================================================================
# SECTION 4: PORTFOLIO ASSUMPTIONS AND TARGETS
# =============================================================================
# client_profile: optional. ultra_conservative | conservative | balanced | growth | aggressive.
# If set, missing targets are filled from config/client_profiles.yml. Override manually as needed.
# Reminder: 1 Ultra Conservative  2 Conservative  3 Balanced  4 Growth  5 Aggressive (full table in Config UI).

client_profile: null

# allow_leverage, allow_short_selling: на выбор true / false.
# Поля в процентах — можно вводить в процентах (15%) или десятичной дробью (0.15):
#   min_acceptable_return, target_nominal_return_annual, target_vol_annual,
#   target_max_drawdown_pct. null допустим.
# horizon_years: число лет (10, 3, 0.5 и т.д.); null допустим.

allow_leverage: false
allow_short_selling: false
min_acceptable_return: null
target_nominal_return_annual: 0.1
target_vol_annual: 0.15
target_max_drawdown_pct: -0.3
horizon_years: 10.0

# =============================================================================
# SECTION 5: OPTIMIZATION CONSTRAINTS
# =============================================================================
# If max_single_security_weight_pct or min_single_security_weight_pct is null or 0,
# max weight per name defaults from docs/docs/feasibility_constraints_spec.md (formula by N).

max_single_security_weight_pct: null
min_single_security_weight_pct: null

# Alpha-shift (when cash_policy = prohibited and vol > target_vol_annual): top N_rc donors by RC_vol.
N_rc: 3
# Donor (Shift Mode): proportional or equal — you can set equal.
donor_shift_mode: proportional

# Advanced Minimum-Variance (run_minimum_variance_advanced.py) — not the primary lowest-volatility-
# under-constrained-box baseline (that is run_minimum_variance.py / minimum_variance_constrained).
# - Optional max vol cap from target_vol_annual: monthly variance w'Σw ≤ target_vol_annual²/12.
# - minimum_variance_turnover_lambda (default 0): pure MinVar on the advanced path when 0.
#   When > 0 and current portfolio weights (cfg / merged portfolio_weights.yml) are valid on the
#   eligible universe, L1 vs current weights is applied (rebalance-aware / turnover-controlled; equal-weight never used).
# - minimum_variance_l1_experimental: legacy field; ignored by Advanced MinVar (L1 is governed only by lambda).
minimum_variance_turnover_lambda: 0
minimum_variance_l1_experimental: false

# =============================================================================
# SECTION 6: ANALYSIS SETTINGS
# =============================================================================
# output_dir: только CSV (по умолчанию results_csv).
# output_dir_final: веса, все JSON, report (по умолчанию Main portfolio).

windows_months: [36, 60, 120]
coverage_threshold: 0.9
output_dir: results_csv
output_dir_final: "Main portfolio"

# Dual-horizon optimization robustness (10Y primary + 5Y secondary validation)
# Primary portfolio is always from primary_window_months; 5Y run is consistency check only.
optimization_windows_months: [120, 60]
primary_window_months: 120
secondary_window_months: 60
robustness_policy:
  enabled: true
  max_weight_change_allowed: 0.10   # 10pp absolute per asset vs 10Y solution
  max_asset_rc_dev_allowed: 0.05    # 5pp RC deviation per asset vs 10Y RC
  min_effective_months: 36          # if join leaves < 36 months, FLAG_SHORT_SAMPLE

# Backtest mode (default: dynamic_nan_safe):
# - dynamic_nan_safe: policy-compliant (global redistribution among risk tickers, RC-gated fallback to cash)
# - simple: opt-in simplified mode, no redistribution / RC-gating
backtest_mode: dynamic_nan_safe
