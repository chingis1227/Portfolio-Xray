      "screen_routes": [],
      "screen_mapping_status": "operator",
      "screen_contract_section": "Run locally / API readiness",
      "mapping_note": "Health is an operator/API readiness endpoint and is not surfaced as a Core MVP screen."
    },
    {
      "operation_id": "createReview",
      "method": "POST",
      "path": "/api/v1/reviews",
      "request_schema": "CreateReviewRequest",
      "success_status": "200",
