      "screen_routes": [
        "/client-profile",
        "/portfolio-input",
        "/diagnosis",
        "/evidence",
        "/client-fit",
        "/hypothesis"
      ],
      "screen_mapping_status": "current",
      "screen_contract_section": "Client Profile -> Portfolio Input -> Portfolio X-Ray / Diagnosis -> Stress Test Lab -> Client Fit -> Hypothesis Builder",
      "mapping_note": "Creates diagnosis-first review state from portfolio input plus optional Client Fit request context. The standard web journey requires Client Profile before diagnosis; backend/CLI compatibility still supports missing Client Fit. Public client_fit is a bounded display summary, not raw client_fit_check.json."
    },
    {
      "operation_id": "recoverReview",
      "method": "GET",
      "path": "/api/v1/reviews/{review_id}",
      "request_schema": null,
      "success_status": "200",
      "response_schema": "ReviewRecoveryResponse",
      "data_schema": "ReviewRecoveryData",
      "public_data_fields": [
        "artifact_refs",
        "diagnosis",
        "client_fit",
        "downstream_artifacts_restored_as_active",
        "launchpad",
        "next_allowed_actions",
        "restored_active_stages",
        "review_summary"
      ],
      "screen_routes": [
        "/portfolio-input",
        "/diagnosis",
        "/evidence",
        "/client-fit",
        "/hypothesis"
      ],
      "screen_mapping_status": "current",
      "screen_contract_section": "Portfolio Input recovery and conservative downstream reset",
      "mapping_note": "Recovery restores diagnosis/evidence/Client Fit/hypothesis setup only and must keep downstream candidate/comparison/verdict/report inactive unless regenerated. Client Fit is exposed only as a bounded display summary, not as raw client_fit_check.json."
    },
    {
      "operation_id": "prepareBuilder",
      "method": "POST",
      "path": "/api/v1/reviews/{review_id}/builder",
      "request_schema": "BuilderRequest",
      "success_status": "200",
      "response_schema": "BuilderResponse",
      "data_schema": "BuilderData",
      "public_data_fields": [
        "builder_setup",
        "candidate_generation_allowed",
        "next_allowed_actions"
      ],
      "screen_routes": [
        "/hypothesis"
      ],
      "screen_mapping_status": "current",
      "screen_contract_section": "Hypothesis Builder",
      "mapping_note": "Builder setup is setup-only. It may enable Generate candidate but must not display weights, comparison, or a verdict."
    },
    {
      "operation_id": "generateCandidate",
      "method": "POST",
      "path": "/api/v1/reviews/{review_id}/candidate",
      "request_schema": "BuilderSetupIdRequest",
      "success_status": "200",
      "response_schema": "CandidateResponse",
      "data_schema": "CandidateData",
      "public_data_fields": [
        "candidate",
        "hypothesis",
        "is_rebalance_recommendation",
        "next_allowed_actions"
      ],
      "screen_routes": [
        "/hypothesis",
        "/comparison"
      ],
      "screen_mapping_status": "current",
      "screen_contract_section": "Hypothesis Builder and Current vs Candidate Comparison gate",
      "mapping_note": "One diagnostic candidate attempt only. Candidate data may unlock comparison when same-run lineage is current; it is not a recommendation."
    },
    {
      "operation_id": "runComparison",
      "method": "POST",
      "path": "/api/v1/reviews/{review_id}/comparison",
      "request_schema": "CandidateIdRequest",
      "success_status": "200",
      "response_schema": "ComparisonResponse",
      "data_schema": "ComparisonData",
      "public_data_fields": [
        "client_fit",
        "comparison",
        "evidence_chain_context",
        "next_allowed_actions"
      ],
      "screen_routes": [
        "/comparison",
        "/verdict",
        "/report"
      ],
      "screen_mapping_status": "current",
      "screen_contract_section": "Current vs Candidate Comparison",
      "mapping_note": "Comparison is trade-off evidence and may unlock Verdict; it carries bounded diagnosis-to-hypothesis context and bounded Client Fit target context, but must not crown a winner or issue action advice. Client Fit is exposed only as a bounded display summary, not as raw client_fit_check.json."
    },
    {
      "operation_id": "generateVerdict",
      "method": "POST",
      "path": "/api/v1/reviews/{review_id}/verdict",
      "request_schema": "ComparisonIdRequest",
      "success_status": "200",
      "response_schema": "VerdictResponse",
      "data_schema": "VerdictData",
      "public_data_fields": [
        "client_fit",
        "next_allowed_actions",
        "evidence_chain_context",
        "verdict"
      ],
      "screen_routes": [
        "/verdict",
        "/report"
      ],
      "screen_mapping_status": "current",
      "screen_contract_section": "Decision Verdict",
      "mapping_note": "Verdict is non-binding decision support over same-run evidence-chain context. No-trade, test-another, failed/infeasible, and evidence-insufficient remain valid outcomes. Client Fit is exposed only as a bounded display summary and cannot by itself clear material diagnostic issues."
    },
    {
      "operation_id": "generateReport",
      "method": "POST",
      "path": "/api/v1/reviews/{review_id}/report",
      "request_schema": "VerdictIdRequest",
      "success_status": "200",
      "response_schema": "ReportResponse",
      "data_schema": "ReportData",
      "public_data_fields": [
        "client_fit",
        "evidence_chain_context",
        "grounding",
        "llm_generated",
        "report_preview"
      ],
      "screen_routes": [
        "/report"
      ],
      "screen_mapping_status": "current",
      "screen_contract_section": "Report / AI Commentary Grounding",
      "mapping_note": "Report is a grounded deterministic preview over diagnosis, hypothesis, comparison, and verdict context. It must not imply LLM generation, PDF generation, or unsupported conclusions. Client Fit is exposed only as a bounded display summary, not as raw client_fit_check.json."
    }
  ]
